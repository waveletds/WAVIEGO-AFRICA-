rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global safety net: Deny all by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Reuseable identity and validation helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Helper for validating User structure
    function isValidUser(data) {
      return data.keys().hasAll(['phone', 'wallet_balance', 'kyc_completed']) &&
             data.phone is string &&
             data.wallet_balance is number &&
             data.kyc_completed is bool &&
             (data.get('email', '') == '' || data.email is string) &&
             (data.get('fullname', '') == '' || data.fullname is string);
    }

    // Helper for validating Transaction structure
    function isValidTransaction(data) {
      return data.keys().hasAll(['type', 'amount', 'status', 'created_at']) &&
             data.type in ['deposit', 'transfer', 'vtu'] &&
             data.amount is number &&
             data.status in ['success', 'pending', 'failed'] &&
             data.created_at is string;
    }

    // Users Collection
    match /users/{userId} {
      // In this specific demo, we allow the server (which might be unauthenticated in the rules check)
      // or the specific owner to read/write. 
      // For the sandbox 'default_user' pattern, we'll be slightly permissive but structured.
      allow get: if true; // Public read for the demo account
      allow list: if false; // No directory listing
      
      allow create: if isValidId(userId) && isValidUser(request.resource.data);
      
      allow update: if isValidUser(request.resource.data) && (
        // Allow partial updates for balance or KYC steps
        request.resource.data.diff(resource.data).affectedKeys().hasAny([
          'wallet_balance', 'kyc_step', 'kyc_completed', 'pin', 'fullname', 'email', 'updatedAt'
        ])
      );
      
      // Transactions Subcollection
      match /transactions/{transactionId} {
        allow read: if true;
        allow create: if isValidTransaction(request.resource.data);
        allow update, delete: if false; // Transactions are immutable once written
      }
    }

    // OTPs Collection
    match /otps/{phone} {
      allow read: if true;
      allow create, update: if request.resource.data.keys().hasAll(['code', 'createdAt']) &&
                              request.resource.data.code is string &&
                              request.resource.data.code.size() == 4;
      allow delete: if true;
    }
  }
}
